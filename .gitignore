# ============================================================
# MAXX BYTE - .gitignore
# ============================================================

# ============================================================
# DATABASE FILES (Most Important)
# ============================================================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ============================================================
# VIRTUAL ENVIRONMENT
# ============================================================
venv/
env/
ENV/
.venv/
venv.bak/
env.bak/

# ============================================================
# IDE FILES
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
.env
.env.local
.env.*.local
*.key
*.pem
*.crt

# ============================================================
# LOGS AND TEMP FILES
# ============================================================
*.log
*.tmp
*.temp
*.bak
*.cache

# ============================================================
# SECRETS
# ============================================================
secrets/
*.secret
password.txt
credentials.json

# ============================================================
# TEST AND COVERAGE
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# ============================================================
# DJANGO SPECIFIC
# ============================================================
*.log
staticfiles/
media/
*.pyc
local_settings.py
db.sqlite3
migrations/*.pyc

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
# DATA FILES (Keep schema, not data)
# ============================================================
*.csv
*.xlsx
*.parquet
data/

# ============================================================
# BACKUPS
# ============================================================
*.backup
backups/
*.old
